# ---- 平台密钥池（用户零配置即可用）----
# LLM：Agent SDK 跑管道所需（走 Anthropic Messages 协议，但端点不限于 Anthropic）。四选一：
#   (a) 本地开发：三项留空 → 用本机登录的 claude 凭证。
#   (b) ★DeepSeek 直连【线上默认·推荐】：编排器即 DeepSeek，全流程实测 ~$0.04/篇（比 Claude 便宜 ~130×），
#       完成度更干净、原生支持 WebSearch。claude CLI ≥2.1 直接驱动其 Anthropic 兼容端点：
#         ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
#         ANTHROPIC_AUTH_TOKEN=<DeepSeek key>
#         WEWRITE_MODEL=deepseek-v4-pro     （见下方运行参数；ANTHROPIC_API_KEY 留空）
#       此模式下编排器自写正文，**把下面的混合路由留空**（无需再卸载生成）。文档：
#       https://api-docs.deepseek.com/zh-cn/quick_start/agent_integrations/claude_code
#   (c) 官方 Claude API：ANTHROPIC_API_KEY=sk-ant-...（默认走 api.anthropic.com）。
#   (d) 第三方 relay 的真 Claude：ANTHROPIC_BASE_URL 指向网关根 + ANTHROPIC_AUTH_TOKEN 填 key。
#       ⚠️ relay 必须真正映射到 Anthropic Claude（拿 claude-* id 实测应返回真 Claude，
#          而非被静默路由到 GPT）；用 claude-* 跑时 SDK 需真 Claude，套壳 GPT 网关不可用。
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=

# 混合路由（可选·仅当用 Claude 当编排时才需要）：把"内容生成"卸载给便宜的写作模型（DeepSeek 等，
# OpenAI 兼容协议），Claude 仍当编排，正文由 scripts/llm_write.py 出稿。
# ⚠️ 实测 Claude 编排时不肯稳定调用该工具（指令遵循问题），且编排开销才是成本大头——
#    所以推荐直接用上面的 (b) DeepSeek 直连编排，而非这条混合路由。用 (b) 时此处全部留空。
WEWRITE_WRITER_PROVIDER=deepseek
WEWRITE_WRITER_API_KEY=
WEWRITE_WRITER_BASE_URL=https://api.deepseek.com
WEWRITE_WRITER_MODEL=deepseek-chat
WEWRITE_WRITER_TEMPERATURE=1.0

# AI 图片生成（平台统一出，任选一个 provider；见仓库根 config.example.yaml）
WEWRITE_IMAGE_PROVIDER=doubao
WEWRITE_IMAGE_API_KEY=
# 即梦(jimeng) 需要 access_key_id + secret_key 两段
WEWRITE_IMAGE_SECRET_KEY=
# 自定义图片服务（如 Sub2API 网关走 gpt-image-2）：provider=sub2api，填 base_url + model
#   WEWRITE_IMAGE_PROVIDER=sub2api
#   WEWRITE_IMAGE_BASE_URL=https://relay.upthos.com
#   WEWRITE_IMAGE_MODEL=gpt-image-2
WEWRITE_IMAGE_BASE_URL=
WEWRITE_IMAGE_MODEL=

# ---- 安全 ----
# 用于加密用户绑定的微信 appid/secret。生成：python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
APP_SECRET_KEY=

# ---- 运行参数 ----
# WeWrite skill 仓库根目录（含 SKILL.md / toolkit / scripts / references）。默认自动定位到本仓库根。
WEWRITE_SKILL_DIR=
# 跑管道用的模型。配 (b) DeepSeek 直连时填 deepseek-v4-pro；配 Claude 时填 claude-sonnet-4-6 / claude-opus-4-8。
WEWRITE_MODEL=deepseek-v4-pro
# 每个任务工作区的根目录（默认系统临时目录）
WEWRITE_WORKSPACE_ROOT=
# 生成图片的持久化目录（工作区清理后仍保留，供预览与发布）。生产建议换对象存储。
WEWRITE_ARTIFACT_ROOT=
# 产物公开基址（可选）。设了则 markdown 里的图片用绝对 URL，否则用相对 /artifacts/...
WEWRITE_PUBLIC_BASE_URL=
# 允许的前端来源（CORS），逗号分隔
WEWRITE_CORS_ORIGINS=http://localhost:3000
# 单任务最大轮数（防失控）
WEWRITE_MAX_TURNS=120

# ---- P1 并发 + 容器沙箱 ----
# runner：direct=进程内（本地，用宿主登录的 claude）；container=每任务 Docker 沙箱（线上，走 relay）
WEWRITE_RUNNER=direct
WEWRITE_MAX_CONCURRENT_JOBS=3   # 全局同时跑的任务数
WEWRITE_MAX_PER_USER_JOBS=1     # 单用户在途上限
WEWRITE_JOB_IMAGE=wewrite-job:latest
WEWRITE_JOB_CPUS=2
WEWRITE_JOB_MEMORY=2g
WEWRITE_JOB_PIDS=512
WEWRITE_JOB_TIMEOUT=1200        # 单任务超时（秒）
WEWRITE_JOB_NETWORK=wewrite-jobs  # 任务容器专用 docker 网络（配宿主防火墙规则）

# ---- 多平台发布 ----
# 小红书：部署 xiaohongshu-mcp (https://github.com/xpzouying/xiaohongshu-mcp) 后填其 MCP 端点
XHS_MCP_URL=
